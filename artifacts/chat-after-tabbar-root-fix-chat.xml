" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[97,302][846,509]" /><node index="3" text="16:59" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[97,530][846,573]" /><node index="4" text="" resource-id="" class="android.view.ViewGroup" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[53,639][891,1392]" /><node index="5" text="今日微调建议：补齐活动量，ACT +12 min。今天午餐后血糖偏高，峰值出现在下午两点，建议晚餐先吃蔬菜和蛋白质，最后吃主食，帮助延缓糖分吸收。全天热量已接近目标，晚餐可减少半碗米饭或面条。今日步数偏少，晚饭后休息半小时再散步20分钟，有助于降低餐后血糖峰值。" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[97,673][846,1294]" /><node index="6" text="16:59" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[97,1315][846,1358]" /><node index="7" text="" resource-id="" class="android.view.ViewGroup" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[651,1424][1029,1625]" /><node index="8" text="喝了一瓶可乐" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[695,1458][983,1527]" /><node index="9" text="16:59" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[695,1548][983,1591]" /><node index="10" text="" resource-id="" class="android.view.ViewGroup" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[53,1656][891,1951]" /><node index="11" text="已写入后端归档：热量 215 kcal、8 小时血糖预测。当前建议更新为抑制餐后波动，CHO -18 g。今天午餐后血糖偏高，且总热量已接近目标上限，建议晚餐减少主食至平时一半，优先吃绿叶蔬菜和优质蛋白。全天步数偏少，晚餐后20分钟可出门散步或原地踏步，有助于平稳睡前血糖。请保持当前饮水节奏，避免夜间加餐。" resource-id="" class="android.widget.TextView" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[97,1690][846,1951]" /></node></node><node index="1" text="" resource-id="" class="android.view.ViewGroup" package="com.healthtrack.mobile" content-desc="" checkable="false" checked="false" clickable="false" enabled="true" focusable="false" focused="false" scrollable="false" long-clickable="false" password="false" selected="false" bounds="[0,1951][1080,2111]"><node index="0" text="描述今天的饮食、运动、睡眠或身体变化..." resource-id="" class="android.widget.EditText" package=